# ============================================================
# Configuracion del EcoAsistente Multimodal - version Gemini API
# Copiar este archivo como .env y ajustar los valores.
# Esta version NO ejecuta modelos localmente.
# ============================================================

# API key de Gemini. Se obtiene desde Google AI Studio.
# No compartir ni subir a GitHub.
GEMINI_API_KEY=

# Endpoint REST de Gemini API. Normalmente no hace falta modificarlo.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Modelo multimodal para interpretar la imagen del residuo.
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# Modelo de texto para generar la respuesta final.
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# Modelo de embeddings para el indice vectorial del RAG.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# Rutas del proyecto
DOCS_DIR=data/docs
VECTORSTORE_DIR=data/vectorstore
UPLOAD_DIR=static/uploads
LOG_DIR=logs

# Parametros RAG
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4

# Flask
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Timeouts para llamadas remotas, en segundos
VISION_TIMEOUT_SECONDS=60
TEXT_TIMEOUT_SECONDS=90
EMBEDDING_TIMEOUT_SECONDS=60

# Auditoria / evaluacion
ENABLE_ANSWER_EVALUATOR=true
OUTPUTS_DIR=outputs
